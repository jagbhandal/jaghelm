# ── JagHelm Configuration ──
# Required: these two URLs are all you need to get started.
PROMETHEUS_URL=http://localhost:9090
KUMA_URL=http://localhost:3001

# Required for encrypted secrets (generate once: openssl rand -hex 32)
DASH_SECRET=your-random-secret-here

# Optional: Dashboard port
PORT=3099

# Optional: Dashboard authentication (leave DASH_PASS empty to disable login)
DASH_USER=admin
DASH_PASS=

# ── Power-user overrides (optional) ──
# If set, these override the equivalent UI/yaml config.
# Most users should configure these via the Settings UI instead.

# AdGuard Home
# ADGUARD_URL=http://192.168.68.13:8085
# ADGUARD_USER=admin
# ADGUARD_PASS=secret

# Nginx Proxy Manager
# NPM_URL=http://192.168.68.13:81
# NPM_USER=admin@example.com
# NPM_PASS=secret

# Gitea
# GITEA_URL=http://localhost:3060
# GITEA_TOKEN=your-token
# GITEA_REPO=user/repo

# PhotoPrism
# PHOTOPRISM_URL=http://photoprism:2342
# PHOTOPRISM_USER=admin
# PHOTOPRISM_PASS=secret
