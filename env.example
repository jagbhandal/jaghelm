# ── JagHelm Configuration ──
# Required: these two URLs are all you need to get started.
PROMETHEUS_URL=http://localhost:9090
KUMA_URL=http://localhost:3001

# Required for encrypted secrets (generate once: openssl rand -hex 32)
DASH_SECRET=your-random-secret-here

# Optional: Dashboard port
PORT=3099

# Optional: Dashboard authentication (leave DASH_PASS empty to disable login)
DASH_USER=admin
DASH_PASS=

# ── Power-user overrides (optional) ──
# If set, these override the equivalent UI/yaml config.
# Most users should configure integrations via Settings UI instead.
# All integration env vars use the JAGHELM_ prefix to avoid
# colliding with service env vars in shared Docker networks.

# JAGHELM_ADGUARD_URL=http://192.168.68.13:8085
# JAGHELM_ADGUARD_USER=admin
# JAGHELM_ADGUARD_PASS=secret

# JAGHELM_NPM_URL=http://192.168.68.13:81
# JAGHELM_NPM_USER=admin@example.com
# JAGHELM_NPM_PASS=secret

# JAGHELM_GITEA_URL=http://localhost:3060
# JAGHELM_GITEA_TOKEN=your-token
